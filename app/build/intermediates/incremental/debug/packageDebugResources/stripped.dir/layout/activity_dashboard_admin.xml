<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:background="@drawable/wave_shape">


    <TextView
        android:id="@+id/welcomeTextView"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/benvenuto"
        android:textColor="@android:color/black"
        android:textSize="24sp"
        android:textStyle="bold" />
    <!-- Pulsante per Gestione Clienti -->
    <Button
        android:id="@+id/btn_gestione_sviluppatori"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:padding="12dp"
        android:text="@string/gestione_sviluppatori" />
    <Button
        android:id="@+id/btn_gestione_clienti"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:text="@string/gestione_clienti" />

    <!-- Pulsante per Gestione Pacchetti -->
    <Button
        android:id="@+id/btn_gestione_pacchetti"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/gestione_pacchetti" />

</LinearLayout>
